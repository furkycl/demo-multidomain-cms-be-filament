APP_NAME="multi-cms"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

# Local: SQLite. Production: Postgres (Neon)
DB_CONNECTION=sqlite
# DATABASE_URL=postgresql://user:pass@ep-foo-bar.eu-central-1.aws.neon.tech/multi_cms?sslmode=require

BROADCAST_CONNECTION=log
CACHE_STORE=database
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database
SESSION_DRIVER=database
SESSION_LIFETIME=120

MAIL_MAILER=log

# Cloudflare R2 (production)
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT=
R2_URL=

# Frontend revalidation
FRONTEND_REVALIDATE_TIMEOUT=5

# i18n
DEFAULT_LOCALE=tr

# Lead routing — CRM endpoints
# tr/en/ar  → omnigos (Topstudy)
# fr/es/pt/ko/ja/it/de → linguland
# Boş bırakılırsa lead sadece DB'ye yazılır (demo modu).
OMNIGOS_LEAD_ENDPOINT=
OMNIGOS_API_KEY=
OMNIGOS_TIMEOUT=5

LINGULAND_LEAD_ENDPOINT=
LINGULAND_API_KEY=
LINGULAND_TIMEOUT=5

# Filament
FILAMENT_DOMAIN=
